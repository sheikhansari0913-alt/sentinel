<Application x:Class="Sentinel.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             StartupUri="Views/MainWindow.xaml">
    <Application.Resources>
        <SolidColorBrush x:Key="BgBrush"      Color="#0F1115"/>
        <SolidColorBrush x:Key="PanelBrush"   Color="#171A21"/>
        <SolidColorBrush x:Key="AccentBrush"  Color="#4FC3F7"/>
        <SolidColorBrush x:Key="WarnBrush"    Color="#FFB74D"/>
        <SolidColorBrush x:Key="DangerBrush"  Color="#EF5350"/>
        <SolidColorBrush x:Key="TextBrush"    Color="#E6E6E6"/>
        <SolidColorBrush x:Key="MutedBrush"   Color="#8A8F98"/>

        <Style TargetType="Button">
            <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
            <Setter Property="Foreground" Value="#0F1115"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
        </Style>
    </Application.Resources>
</Application>
